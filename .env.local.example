# Copy this file to .env.local and fill in your values

# Resend API key — get from resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin notification email
ADMIN_EMAIL=insyncpt.manager@gmail.com

# From address (must be a verified domain in Resend)
EMAIL_FROM=InSync Physical Therapy <noreply@insync-pt.com>

# Site URL (used for canonical meta tags)
NEXT_PUBLIC_SITE_URL=https://insync-pt.com
